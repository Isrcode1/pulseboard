# ── GitHub OAuth App (create at https://github.com/settings/developers) ──
GITHUB_CLIENT_ID=your_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_oauth_app_client_secret

# Where GitHub redirects after login — must match the OAuth App settings.
# Through the local nginx stack this is:
GITHUB_REDIRECT_URI=http://localhost/api/auth/auth/github/callback

# ── Auth ─────────────────────────────────────────────────
# Generate one with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-something-random
